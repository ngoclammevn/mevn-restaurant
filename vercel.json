{
  "devCommand": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/share/:id", "destination": "/api/share?id=:id" },
    { "source": "/menu/:id", "destination": "/api/share?id=:id" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
